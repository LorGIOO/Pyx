# Normalize line endings: LF in the repo, checked out native on each OS.
* text=auto eol=lf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.pdf binary
*.gz binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
