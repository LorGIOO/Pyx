{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pyx",
  "version": "1.0.0",
  "identifier": "com.pyx.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3042",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pyx",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "backgroundColor": "#1f1f1f",
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob: https:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https:; img-src 'self' blob: data: https:; font-src 'self' data: https:; media-src 'self' blob: data:; connect-src 'self' ipc: http://ipc.localhost https:",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/pltx.ico": "pltx.ico"
    },
    "fileAssociations": [
      {
        "ext": ["pltx"],
        "name": "Pyx Document",
        "description": "Documento Pyx (LaTeX + Python)",
        "role": "Editor"
      }
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
